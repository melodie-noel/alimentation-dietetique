---
layout: base.njk
permalink: "/accompagnements.html"
navId: "accompagnements"
title: "Accompagnements — Diététique & hypnose | Mélodie Noël, Maisons-Alfort"
description: "Accompagnement diététique et nutritionnel sur mesure, et hypnose ericksonienne pour apaiser votre rapport à l'alimentation. Cabinet à Maisons-Alfort & téléconsultation. Pas de régime, pas de privation."
themeColor: "#F3AE26"
ogTitle: "Accompagnements — Mélodie Noël, Diététique & Hypnose"
ogDescription: "Manger avec plaisir, vivre en équilibre. Un accompagnement sur mesure, sans régime ni privation."
---
<main id="main">

  <!-- HERO -->
  <section class="page-hero page-hero--gold">
    <div class="wrap">
      <p class="eyebrow">{{ accompagnements.hero.eyebrow }}</p>
      <h1>{{ accompagnements.hero.titleBefore }}<span class="hand">{{ accompagnements.hero.titleHand }}</span>{{ accompagnements.hero.titleAfter }}</h1>
      <p class="lead">{{ accompagnements.hero.lead }}</p>
    </div>
  </section>

  <!-- LES SÉANCES DIÉTÉTIQUE -->
  <section class="sec" id="dietetique">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.dietetique.eyebrow }}</p>
        <h2>{{ accompagnements.dietetique.title }}</h2>
      </div>
      <p class="lead" style="max-width:54em">{{ accompagnements.dietetique.lead }}</p>
      <div class="duo">
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4.5h6V7H9z"/><path d="M9 11.5h6M9 15h4"/></svg></span>
          <h3>{{ accompagnements.dietetique.card1Title }}</h3>
          <p>{{ accompagnements.dietetique.card1Text }}</p>
        </article>
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19h16"/><path d="M7 19v-4M12 19v-7M17 19v-11"/><path d="M15 8l2-2 2 2"/></svg></span>
          <h3>{{ accompagnements.dietetique.card2Title }}</h3>
          <p>{{ accompagnements.dietetique.card2Text }}</p>
        </article>
      </div>
      <div style="text-align:center;margin-top:30px"><a class="btn btn-dark" href="{{ accompagnements.dietetique.ctaHref }}">{{ accompagnements.dietetique.ctaLabel }}</a></div>
    </div>
  </section>

  <!-- MON INGRÉDIENT SECRET (HYPNOSE) -->
  <section class="sec acid" id="hypnose">
    <div class="wrap split">
      <div>
        <div class="sec-head">
          <p class="eyebrow">{{ accompagnements.hypnose.eyebrow }}</p>
          <h2>{{ accompagnements.hypnose.title }}</h2>
        </div>
        <p class="lead">{{ accompagnements.hypnose.lead }}</p>
        <p>{{ accompagnements.hypnose.intro }}</p>
        <ul class="feature-list">
{% for it in accompagnements.hypnose.items %}          <li><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="#4E9D3F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg> <span><strong>{{ it.strong }}</strong> — {{ it.text }}</span></li>
{% endfor %}        </ul>
        <a class="btn btn-out" href="{{ accompagnements.hypnose.ctaHref }}">{{ accompagnements.hypnose.ctaLabel }}</a>
      </div>
      <aside class="quote-block">
        <p>« {{ accompagnements.hypnose.quote }} »</p>
        <cite>{{ accompagnements.hypnose.quoteCite }}</cite>
      </aside>
    </div>
  </section>

  <!-- BANDE : à chacun sa façon -->
  <section class="sec">
    <div class="wrap">
      <p class="highlight-band">{{ accompagnements.band.textBefore }}<span class="hand">{{ accompagnements.band.textHand }}</span></p>
    </div>
  </section>

  <!-- STOP AUX IDÉES REÇUES -->
  <section class="sec alt" id="idees-recues">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.idees.eyebrow }}</p>
        <h2>{{ accompagnements.idees.title }}</h2>
      </div>
      <ul class="myths">
{% for m in accompagnements.idees.myths %}        <li>« {{ m }} »</li>
{% endfor %}      </ul>
      <p class="lead" style="text-align:center;max-width:48em;margin:26px auto 0">{{ accompagnements.idees.note }}</p>
    </div>
  </section>

  <!-- DÉROULÉ D'UNE SÉANCE -->
  <section class="sec" id="deroule">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.deroule.eyebrow }}</p>
        <h2>{{ accompagnements.deroule.title }}</h2>
      </div>
      <p class="lead" style="max-width:54em;margin:0 auto;text-align:center">{{ accompagnements.deroule.text }}</p>
    </div>
  </section>

  <!-- MON APPROCHE -->
  <section class="sec acid" id="approche">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.approche.eyebrow }}</p>
        <h2>{{ accompagnements.approche.title }}</h2>
      </div>
      <div class="approach-grid">
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#4E9D3F" stroke-width="2"/><path d="M12 7.5V12l3 2" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h3>{{ accompagnements.approche.card1Title }}</h3>
          <p>{{ accompagnements.approche.card1Text }}</p>
        </article>
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#4E9D3F" stroke-width="2"/><path d="M8.5 14c.9 1.1 2.1 1.7 3.5 1.7s2.6-.6 3.5-1.7" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="10" r="1" fill="#4E9D3F"/><circle cx="15" cy="10" r="1" fill="#4E9D3F"/></svg></span>
          <h3>{{ accompagnements.approche.card2Title }}</h3>
          <p>{{ accompagnements.approche.card2Text }}</p>
        </article>
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 6h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H10l-4 3v-3H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z" stroke="#4E9D3F" stroke-width="2" stroke-linejoin="round"/></svg></span>
          <h3>{{ accompagnements.approche.card3Title }}</h3>
          <p>{{ accompagnements.approche.card3Text }}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section class="sec" id="tarifs">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.tarifs.eyebrow }}</p>
        <h2>{{ accompagnements.tarifs.title }}</h2>
      </div>
      <p class="lead" style="margin-bottom:6px">{{ accompagnements.tarifs.lead }}</p>
      <table class="tarif-table">
        <thead><tr><th scope="col">Prestation</th><th scope="col">Durée</th><th scope="col" class="r">Tarif</th></tr></thead>
        <tbody>
{% for r in accompagnements.tarifs.rows %}          <tr><td class="nm">{{ r.nom }}</td><td>{{ r.duree }}</td><td class="pr">{{ r.prix }}&nbsp;€</td></tr>
{% endfor %}        </tbody>
      </table>
      <p class="tarif-note">{{ accompagnements.tarifs.note }}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="wrap">
      <h2>{{ accompagnements.cta.title }}</h2>
      <p>{{ accompagnements.cta.text }}</p>
      <a class="btn btn-dark" href="{{ accompagnements.cta.ctaHref }}" target="_blank" rel="noopener">{{ accompagnements.cta.ctaLabel }}</a>
    </div>
  </section>

</main>
