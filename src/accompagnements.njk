---
layout: base.njk
permalink: "/accompagnements.html"
navId: "accompagnements"
title: "Accompagnements — Diététique & hypnose | Mélodie Noël, Maisons-Alfort"
description: "Accompagnement diététique et nutritionnel sur mesure, et hypnose ericksonienne pour apaiser votre rapport à l'alimentation. Cabinet à Maisons-Alfort & téléconsultation. Pas de régime, pas de privation."
themeColor: "#F3AE26"
ogTitle: "Accompagnements — Mélodie Noël, Diététique & Hypnose"
ogDescription: "Manger avec plaisir, vivre en équilibre. Un accompagnement sur mesure, sans régime ni privation."
---
<main id="main">

  <!-- HERO -->
  <section class="page-hero page-hero--gold">
    <div class="wrap page-hero-split">
      <div class="page-hero-text">
        <p class="eyebrow">{{ accompagnements.hero.eyebrow }}</p>
        <h1>{{ accompagnements.hero.titleBefore }}<span class="hand">{{ accompagnements.hero.titleHand }}</span>{{ accompagnements.hero.titleAfter }}</h1>
        <p class="lead">{{ accompagnements.hero.lead }}</p>
      </div>
      <div class="page-hero-illus page-hero-illus--food" aria-hidden="true"><img src="assets/img/hero-accompagnements.webp" alt="" width="676" height="1263" loading="eager"></div>
    </div>
  </section>

  <!-- 1 · MON APPROCHE -->
  <section class="sec" id="approche">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.approche.eyebrow }}</p>
        <h2>{{ accompagnements.approche.title }}</h2>
      </div>
      <div class="approach-grid">
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#4E9D3F" stroke-width="2"/><path d="M12 7.5V12l3 2" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <h3>{{ accompagnements.approche.card1Title }}</h3>
          <p>{{ accompagnements.approche.card1Text }}</p>
        </article>
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#4E9D3F" stroke-width="2"/><path d="M8.5 14c.9 1.1 2.1 1.7 3.5 1.7s2.6-.6 3.5-1.7" stroke="#4E9D3F" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="10" r="1" fill="#4E9D3F"/><circle cx="15" cy="10" r="1" fill="#4E9D3F"/></svg></span>
          <h3>{{ accompagnements.approche.card2Title }}</h3>
          <p>{{ accompagnements.approche.card2Text }}</p>
        </article>
        <article class="approach-card">
          <span class="ico" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 6h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H10l-4 3v-3H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z" stroke="#4E9D3F" stroke-width="2" stroke-linejoin="round"/></svg></span>
          <h3>{{ accompagnements.approche.card3Title }}</h3>
          <p>{{ accompagnements.approche.card3Text }}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- 2 · MES SPÉCIALITÉS (regroupe diététique + hypnose) -->
  <section class="sec alt" id="specialites">
    <div class="wrap">
      <div class="spec-panel spec-panel--intro">
        <div class="sec-head sec-head--center">
          <p class="eyebrow">{{ accompagnements.specialites.eyebrow }}</p>
          <h2>{{ accompagnements.specialites.title }}</h2>
          <p class="lead">{{ accompagnements.specialites.intro }}</p>
        </div>
      </div>

      <!-- a) Le pilier : la diététique -->
      <div class="spec-panel spec-tool" id="dietetique">
        <div class="spec-label">
          <span class="spec-no spec-no--diet" aria-hidden="true">1</span>
          <span class="spec-name">Le pilier&nbsp;: la diététique</span>
        </div>
        <h3 class="spec-title">{{ accompagnements.dietetique.title }}</h3>
        <p class="lead" style="max-width:54em">{{ accompagnements.dietetique.lead }}</p>

        <div class="diet-duo">
          <article class="diet-card">
            <div class="diet-thumb" aria-hidden="true"><img src="assets/img/diet-bilan.webp" alt="" width="731" height="950" loading="lazy"></div>
            <div class="diet-card-head">
              <span class="diet-num" aria-hidden="true">1</span>
              <div><h3 class="diet-card-ttl">{{ accompagnements.dietetique.card1Title }}</h3><p class="diet-card-sub">{{ accompagnements.dietetique.card1Sub }}</p></div>
            </div>
            <ul class="diet-kw">
{% for l in accompagnements.dietetique.card1Lines %}              <li>{{ l }}</li>
{% endfor %}            </ul>
          </article>
          <article class="diet-card">
            <div class="diet-thumb" aria-hidden="true"><img src="assets/img/diet-suivi.webp" alt="" width="745" height="903" loading="lazy"></div>
            <div class="diet-card-head">
              <span class="diet-num" aria-hidden="true">2</span>
              <div><h3 class="diet-card-ttl">{{ accompagnements.dietetique.card2Title }}</h3><p class="diet-card-sub">{{ accompagnements.dietetique.card2Sub }}</p></div>
            </div>
            <ul class="diet-kw">
{% for l in accompagnements.dietetique.card2Lines %}              <li>{{ l }}</li>
{% endfor %}            </ul>
          </article>
        </div>

        <!-- Zoom : l'impédancemètre -->
        {% set imp = accompagnements.dietetique.impedance %}
        <div class="imped">
          <div class="imped-main">
            <h3 class="se-title imped-ttl"><span class="imped-kick">{{ imp.eyebrow }}</span>{{ imp.title }}</h3>
            <ul class="imped-kw">
{% for l in imp.lines %}              <li><svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7" stroke="#4E9D3F" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg><span>{{ l }}</span></li>
{% endfor %}            </ul>
            <button type="button" class="imped-thumb" data-lightbox="{{ imp.chartFull }}" data-caption="{{ imp.chartCaption }}" aria-label="{{ imp.chartLabel }} (agrandir l'image)">
              <img src="{{ imp.chartThumb }}" alt="{{ imp.chartCaption }}" width="1800" height="1273" loading="lazy">
              <span class="imped-thumb-tag"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M16 16l4 4M11 8v6M8 11h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>{{ imp.chartLabel }}</span>
            </button>
          </div>
          <aside class="imped-reassure">
            <p class="imped-reassure-strong"><span class="hand">{{ imp.reassureStrong }}</span></p>
            <p class="imped-reassure-text">{{ imp.reassureText }}</p>
          </aside>
        </div>

        <div class="sec-cta"><a class="btn btn-dark" href="{{ accompagnements.dietetique.ctaHref }}" target="_blank" rel="noopener">{{ accompagnements.dietetique.ctaLabel }}</a></div>
      </div>

      <!-- b) L'ingrédient secret : l'hypnose -->
      <div class="spec-panel spec-tool" id="hypnose">
        <div class="spec-label">
          <span class="spec-no spec-no--hyp" aria-hidden="true">2</span>
          <span class="spec-name">{{ accompagnements.hypnose.eyebrow }}</span>
        </div>
        <h3 class="spec-title">{{ accompagnements.hypnose.title }}</h3>
        <p class="lead" style="max-width:52em">{{ accompagnements.hypnose.lead }}</p>
        <p class="hypnose-intro">{{ accompagnements.hypnose.intro }}</p>
        <ul class="theme-grid">
{% for it in accompagnements.hypnose.items %}          <li><span class="th"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7" stroke="#4E9D3F" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg><strong>{{ it.strong }}</strong></span><em>{{ it.text }}</em></li>
{% endfor %}        </ul>

        <div class="hyp-quote-row">
          <figure class="pullquote">
            <p>« {{ accompagnements.hypnose.quote }} »</p>
            <figcaption>{{ accompagnements.hypnose.quoteCite }}</figcaption>
          </figure>

          <div class="deroule deroule--hyp">
            <div class="deroule-head">
              <span class="spec-ic" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#B85420" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg></span>
              <div class="deroule-ttl"><h3 class="se-title">Le déroulé d'une séance</h3><p class="deroule-sub">45&nbsp;min à 1&nbsp;h, simplement assis·e au cabinet.</p></div>
            </div>
            <ul class="deroule-steps">
              <li>Un échange</li>
              <li>De l'écoute</li>
              <li>Un objectif</li>
              <li>Un protocole</li>
              <li>Un temps de travail intérieur</li>
            </ul>
          </div>
        </div>

        <!-- idées reçues : propre à l'hypnose -->
        <div class="myths-block">
          <h4 class="se-title">{{ accompagnements.idees.title }}</h4>
          <ul class="myths myths-center">
{% for m in accompagnements.idees.myths %}            <li>« {{ m }} »</li>
{% endfor %}          </ul>
          <p class="info-note">{{ accompagnements.idees.note }}</p>
        </div>

        <p class="experiment-line">{{ accompagnements.idees.experiment }}</p>
        <div class="sec-cta"><a class="btn btn-dark" href="{{ accompagnements.hypnose.ctaHref }}" target="_blank" rel="noopener">{{ accompagnements.hypnose.ctaLabel }}</a></div>
      </div>
    </div>
  </section>

  <!-- 3 · POUR QUI · POUR QUOI (niveau secondaire) -->
  {% set picto = {
    "Enfants": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.6" cy="6.2" r="1.9"/><circle cx="16.4" cy="6.2" r="1.9"/><circle cx="12" cy="12.6" r="6"/><path d="M9.9 15c.55.7 1.3 1 2.1 1s1.55-.3 2.1-1"/><circle cx="9.8" cy="11.6" r=".5" fill="#4E9D3F" stroke="none"/><circle cx="14.2" cy="11.6" r=".5" fill="#4E9D3F" stroke="none"/></svg>',
    "Adolescents": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13v-1a7 7 0 0 1 14 0v1"/><rect x="3.4" y="13" width="3.6" height="6" rx="1.5"/><rect x="17" y="13" width="3.6" height="6" rx="1.5"/></svg>',
    "Adultes": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.4"/><path d="M5.6 19c0-3.4 2.9-5.6 6.4-5.6s6.4 2.2 6.4 5.6"/></svg>',
    "Séniors": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9.4" cy="5" r="2.3"/><path d="M9.4 7.3c-.7 2.1-1 4.3-1.1 6.6"/><path d="M8.3 13.9 7 19"/><path d="M8.3 13.9 10.1 19"/><path d="M9.1 9.6l3 1.2"/><path d="M14.2 8.7v10.4"/><path d="M14.2 8.7c1.4 0 2 .9 2 1.9"/></svg>',
    "Femmes enceintes": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8.4"/><path d="M12 16c-2.3-1.5-3.8-2.9-3.8-4.6 0-1 .8-1.8 1.8-1.8.8 0 1.4.4 2 1.1.6-.7 1.2-1.1 2-1.1 1 0 1.8.8 1.8 1.8 0 1.7-1.5 3.1-3.8 4.6Z"/></svg>',
    "Sportifs": '<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#4E9D3F" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 8.5v7M9 7v10M15 7v10M17.5 8.5v7M9 12h6"/></svg>'
  } %}
  <section class="sec" id="pour-qui">
    <div class="wrap">
      <div class="sec-head sec-head--sub">
        <p class="eyebrow">{{ accompagnements.pourqui.eyebrow }}</p>
        <h2>{{ accompagnements.pourqui.title }}</h2>
        <p class="lead">{{ accompagnements.pourqui.lead }}</p>
      </div>
      <div class="pubgrid cascade">
{% for g in accompagnements.pourqui.groups %}        <article class="pubcard reveal">
          <div class="pub-head"><span class="pub-ic" aria-hidden="true">{{ picto[g.nom] | default('') | safe }}</span><div class="pub-id"><h3>{{ g.nom }}</h3>{% if g.age %}<span class="pub-age">{{ g.age }}</span>{% endif %}</div></div>
          <ul class="pub-mots">{% for m in g.mots %}<li>{{ m }}</li>{% endfor %}</ul>
        </article>
{% endfor %}      </div>
    </div>
  </section>

  <!-- TARIFS -->
  <section class="sec alt" id="tarifs">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ accompagnements.tarifs.eyebrow }}</p>
        <h2>{{ accompagnements.tarifs.title }}</h2>
      </div>
      <p class="lead" style="margin-bottom:6px">{{ accompagnements.tarifs.lead }}</p>
      <table class="tarif-table">
        <thead><tr><th scope="col">Prestation</th><th scope="col">Durée</th><th scope="col" class="r">Tarif</th></tr></thead>
        <tbody>
{% for r in accompagnements.tarifs.rows %}          <tr><td class="nm"><span class="nm-main">{{ r.nom }}</span>{% if r.precision %}<span class="nm-sub">{{ r.precision }}</span>{% endif %}</td><td>{{ r.duree }}</td><td class="pr">{{ r.prix }}&nbsp;€</td></tr>
{% endfor %}        </tbody>
      </table>
      <p class="tarif-note">{{ accompagnements.tarifs.note }}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band cta-band--light">
    <div class="wrap">
      <h2>{{ accompagnements.cta.title }}</h2>
      <p>{{ accompagnements.cta.text }}</p>
      <a class="btn btn-dark" href="{{ accompagnements.cta.ctaHref }}" target="_blank" rel="noopener">{{ accompagnements.cta.ctaLabel }}</a>
    </div>
  </section>

</main>
