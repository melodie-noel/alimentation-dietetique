---
layout: base.njk
permalink: "/entreprise.html"
navId: "entreprise"
title: "En entreprise — Ateliers, conférences & consultations nutrition | Mélodie Noël"
description: "Diététique & hypnose en entreprise à Maisons-Alfort et en visio : ateliers, conférences et consultations pour la QVT, réduire l'absentéisme et améliorer le bien-être de vos collaborateurs."
themeColor: "#4E9D3F"
ogTitle: "En entreprise — Mélodie Noël, Diététique & Hypnose"
ogDescription: "Bien manger, mieux travailler. Des interventions originales alliant diététique et hypnose pour vos équipes."
---
<main id="main">

  <!-- HERO -->
  <section class="page-hero page-hero--green has-citrus">
    <img class="citrus citrus--hero" src="assets/img/orange-photo.png" alt="" aria-hidden="true">
    <div class="wrap">
      <p class="eyebrow">{{ entreprise.hero.eyebrow }}</p>
      <h1>{{ entreprise.hero.title | safe }}</h1>
      <p class="lead">{{ entreprise.hero.lead }}</p>
    </div>
  </section>

  <!-- PROMESSES -->
  <section class="sec">
    <div class="wrap">
      <div class="feat-cards cascade">{% for p in entreprise.promesses %}<div class="feat-card"><span class="ico" aria-hidden="true"><img src="{{ p.icon }}" alt="" width="26" height="26"></span><p>{{ p.text }}</p></div>{% endfor %}</div>
    </div>
  </section>

  <!-- POURQUOI -->
  <section class="sec alt">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ entreprise.benefices.eyebrow }}</p>
        <h2>{{ entreprise.benefices.title }}</h2>
      </div>
      <ul class="feature-list grid-2">{% for it in entreprise.benefices.items %}<li><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="#4E9D3F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg> {{ it }}</li>{% endfor %}</ul>
    </div>
  </section>

  <!-- LES MAUX -->
  <section class="sec">
    <div class="wrap" style="text-align:center">
      <div class="sec-head" style="margin:0 auto 14px">
        <p class="eyebrow">{{ entreprise.maux.eyebrow }}</p>
        <h2>{{ entreprise.maux.title }}</h2>
      </div>
      <p class="lead" style="max-width:48em;margin:0 auto 36px">{{ entreprise.maux.lead }}</p>
      {% set sizes = ["sm","big","mid","big","mid","sm","mid","sm"] %}
      {% set delays = ["0s",".5s",".2s",".8s",".3s",".6s",".1s",".4s"] %}
      <div class="maux-bubbles" aria-label="Maux concernés">{% for b in entreprise.maux.bubbles %}<span class="bubble b-{{ b.couleur }} {{ sizes[loop.index0 % 8] }}" style="animation-delay:{{ delays[loop.index0 % 8] }}">{{ b.texte }}</span>{% endfor %}</div>
    </div>
  </section>

  <!-- FORMATS -->
  <section class="sec alt">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ entreprise.formats.eyebrow }}</p>
        <h2>{{ entreprise.formats.title }}</h2>
      </div>
      <div class="approach-grid">{% for c in entreprise.formats.cards %}<article class="approach-card"><span class="ico" aria-hidden="true"><img src="{{ c.icon }}" alt="" width="26" height="26"></span><h3>{{ c.title }}</h3><p>{{ c.text }}</p></article>{% endfor %}</div>
    </div>
  </section>

  <!-- REFERENCES -->
  <section class="sec">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ entreprise.references.eyebrow }}</p>
        <h2>{{ entreprise.references.title }}</h2>
      </div>
      <div class="refs">{% for r in entreprise.references.refs %}<div class="ref"><h3>{{ r.nom }}</h3><ul>{% for l in r.lignes %}<li>{{ l }}</li>{% endfor %}</ul></div>{% endfor %}</div>
    </div>
  </section>

  <!-- IDEES DE SUJET -->
  <section class="sec acid">
    <div class="wrap">
      <div class="sec-head">
        <p class="eyebrow">{{ entreprise.themes.eyebrow }}</p>
        <h2>{{ entreprise.themes.title }}</h2>
        <p class="lead">{{ entreprise.themes.lead | safe }}</p>
      </div>
      <div class="topics cascade" aria-label="Idées de sujet">{% for t in entreprise.themes.items %}<span class="topic t-{{ t.couleur }}"><span class="dot" aria-hidden="true"></span>{{ t.texte }}</span>{% endfor %}</div>
    </div>
  </section>

  <!-- SEANCE INDIVIDUELLE -->
  <section class="sec">
    <div class="wrap">
      <div class="note-box">
        <p class="eyebrow">{{ entreprise.encart.eyebrow }}</p>
        <h3>{{ entreprise.encart.title }}</h3>
        <p>{{ entreprise.encart.text | safe }}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="wrap">
      <h2>{{ entreprise.cta.title }}</h2>
      <p>{{ entreprise.cta.text | safe }}</p>
      <div class="tarifs" style="justify-content:center">
        <a class="btn btn-dark" href="contact.html#formulaire">{{ entreprise.cta.btnContact }}</a>
        <a class="btn btn-out" href="{{ entreprise.cta.flyer }}" target="_blank" rel="noopener" aria-label="Télécharger la plaquette entreprise (PDF)">{{ entreprise.cta.btnPlaquette }}</a>
      </div>
    </div>
  </section>

</main>
