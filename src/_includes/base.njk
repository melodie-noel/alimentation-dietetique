        <li><a href="accompagnements.html"{% if navId == 'accompagnements' %} aria-current="page"{% endif %}>Accompagnements</a></li>
        <li><a href="entreprise.html"{% if navId == 'entreprise' %} aria-current="page"{% endif %}>Entreprise</a></li>
        <li><a href="apropos.html"{% if navId == 'apropos' %} aria-current="page"{% endif %}>À propos</a></li>
        <li><a href="contact.html"{% if navId == 'contact' %} aria-current="page"{% endif %}>Contact</a></li>
        <li class="menu-cta"><a class="cta" href="contact.html">Prendre rendez-vous</a></li>
      </ul>
    </nav>
    <a class="cta" href="contact.html">Prendre rendez-vous</a>
    <button class="burger" id="burger" aria-label="Ouvrir le menu" aria-expanded="false"><span></span><span></span><span></span></button>
